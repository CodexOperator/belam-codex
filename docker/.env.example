# .env.example — Copy to .env and fill in paths
# docker compose reads .env automatically

# Path to cloned belam-codex repo (the workspace)
BELAM_WORKSPACE=/home/ubuntu/belam-codex

# OpenClaw config file (contains Telegram tokens — keep safe!)
OPENCLAW_CONFIG=/home/ubuntu/.openclaw/openclaw.json

# SSH key directory
SSH_DIR=/home/ubuntu/.ssh

# machinelearning repo (optional; comment out if not cloned)
ML_WORKSPACE=/home/ubuntu/machinelearning
